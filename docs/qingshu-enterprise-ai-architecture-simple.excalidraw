      "roundness": null,
      "seed": 2002,
      "version": 1,
      "versionNonce": 3002,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776759578000,
      "link": null,
      "locked": false,
      "text": "一句话理解：青数负责“把数据管好”，QingShuClaw 负责“把能力用起来”。",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "lineHeight": 1.25
    },
    {
