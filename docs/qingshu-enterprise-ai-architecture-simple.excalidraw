      "link": null,
      "locked": false,
      "text": "青数 × QingShuClaw：把企业数据真正变成可直接使用的 AI 能力",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "lineHeight": 1.25
    },
    {
      "id": "subtitle",
      "type": "text",
      "x": 40,
      "y": 62,
      "width": 1200,
      "height": 24,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
